{
  "name": "@mui/x-license",
  "version": "9.0.4",
  "author": "MUI Team",
  "description": "MUI X License verification.",
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/mui/mui-x/issues"
  },
  "homepage": "https://mui.com/x/introduction/licensing/",
  "sideEffects": [
    "./utils/licenseInfo.js",
    "./esm/utils/licenseInfo.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mui/mui-x.git",
    "directory": "packages/x-license"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@mui/utils": "9.0.0",
    "@mui/x-internals": "^9.0.4",
    "@mui/x-telemetry": "^9.0.2"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.js"
      },
      "default": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      }
    },
    "./internals": {
      "import": {
        "types": "./internals/index.d.mts",
        "default": "./internals/index.mjs"
      },
      "require": {
        "types": "./internals/index.d.ts",
        "default": "./internals/index.js"
      },
      "default": {
        "types": "./internals/index.d.mts",
        "default": "./internals/index.mjs"
      }
    }
  },
  "main": "./index.js",
  "types": "./index.d.ts"
}